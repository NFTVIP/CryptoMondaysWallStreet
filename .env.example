# CryptoMondays Wall Street — Environment Variables
# =================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — the API key never leaves your server.
#
# Usage:
#   cp .env.example .env
#   npm install
#   node fetch-events.js

# ── Luma API ──────────────────────────────────────────────────────────────────
# Your Luma API key (keep this secret — server-side only)
# Get it at: https://lu.ma/settings → Integrations → API
LUMA_API_KEY=

# Your calendar's API ID (NOT the URL slug — the internal ID)
# Find it at: lu.ma dashboard → your calendar → Settings → scroll to "API ID"
# Format: cal-xxxxxxxxxxxxxxxx
LUMA_CALENDAR_ID=
